# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Site URL for redirects (local: use a mesma origem que o navegador, ex.: porta 3001 se for o caso)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Supabase → Authentication → URL Configuration:
# - Inclua em "Redirect URLs" a URL exata do callback, ex.:
#   http://localhost:3000/auth/callback
#   http://127.0.0.1:3000/auth/callback
# Se essa URL não estiver na lista, o Supabase volta para a "Site URL" (ex.: produção) com ?code= na raiz.

# Supabase Service Role Key (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (pagamento das avaliações em /applicant/shop)
STRIPE_SECRET_KEY=sk_test_...
# Webhook: após criar o endpoint no Stripe Dashboard, copie o Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...
